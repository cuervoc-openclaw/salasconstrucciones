---
const base = import.meta.env.PUBLIC_WP_BASE_URL;
let landing: any = null;
let sliderRaw: any = null;
if (base) {
    try {
        const res = await fetch(`${base}/wp-json/csalas/v1/landing`);
        if (res.ok) landing = await res.json();
    } catch {}
    try {
        const res = await fetch(`${base}/wp-json/csalas/v1/hero-slider`);
        if (res.ok) sliderRaw = await res.json();
    } catch {}
}
const hero = landing?.hero ?? {
    title: 'Construcción y arreglos confiables',
    subtitle: 'Servicios profesionales para casas, oficinas y departamentos. Electricidad, plomería, pintura y remodelaciones con calidad y seguridad.',
    ctaPrimary: { label: 'Solicitar presupuesto', href: '#contacto' },
    ctaSecondary: { label: 'Llamar ahora', href: '#contacto' },
};
const services = landing?.services ?? [
    { title: 'Electricidad', excerpt: 'Instalaciones, cableado, tableros, iluminación y mantenimiento eléctrico seguro.', icon: 'bolt' },
    { title: 'Plomería', excerpt: 'Tuberías, fugas, calentadores, sanitarios y redes hidráulicas eficientes.', icon: 'pipe' },
    { title: 'Pintura', excerpt: 'Acabados interiores y exteriores, preparación de superficies y recubrimientos.', icon: 'paint' },
    { title: 'Remodelaciones', excerpt: 'Optimización de espacios, acabados, carpintería y obras civiles.', icon: 'home' },
];
const contact = landing?.contact ?? { phone: '', whatsapp: '', email: '' };
const contactCopy = landing?.contactCopy ?? {
    title: 'Listos para ayudarte',
    subtitle: 'Atención rápida y confiable. Agenda una visita o cotiza hoy.',
};
const about = landing?.about ?? {
    title: 'Sobre nosotros',
    text: 'Más de 30 años de experiencia en construcción y trabajos eléctricos. Especialista en electricidad y certificación de planos eléctricos.',
};
const coverage = landing?.coverage ?? {
    title: 'Zonas de cobertura',
    text: 'Atendemos comunas de Santiago y sectores cercanos.',
};
const sliderEnabled = landing?.sliderEnabled !== false;
const projects = Array.isArray(landing?.projects) ? landing.projects : [];
const testimonials = Array.isArray(landing?.testimonials) ? landing.testimonials : [];
const faqEnabled = landing?.faqEnabled ?? true;
const faqs = faqEnabled
    ? (Array.isArray(landing?.faqs) ? landing.faqs : [
        { question: '¿El presupuesto tiene costo?', answer: 'No, el presupuesto es sin compromiso.' },
        { question: '¿En qué comunas trabajan?', answer: 'En comunas de Santiago y sectores cercanos.' },
        { question: '¿Ofrecen garantía?', answer: 'Sí, todos los trabajos se entregan con garantía.' },
        { question: '¿Hacen urgencias eléctricas?', answer: 'Sí, según disponibilidad horaria.' },
    ])
    : [];

function phoneDigits(v: string) {
    return (v || '').replace(/[^\d]/g, '');
}
const waDigits = phoneDigits(contact.whatsapp || contact.phone);
const whatsappHref = waDigits ? `https://wa.me/${waDigits}` : '#';

function parseComunas(v: string) {
    const raw = (v || '').trim();
    const hasListHints = raw.includes(',') || raw.includes('\n') || raw.includes(';');
    if (!hasListHints) return [];

    let s = raw;
    if (s.includes(':')) s = s.split(':').slice(1).join(':');
    s = s.replace(/\.[\s]*$/g, '');
    s = s.replace(/\by\b/gi, ',');
    s = s.replace(/otras comunas.*$/i, '');

    const parts = s
        .split(/,|\n|;/g)
        .map((t) => t.trim())
        .filter(Boolean);

    const uniq: string[] = [];
    for (const p of parts) {
        if (!uniq.includes(p)) uniq.push(p);
    }
    return uniq.slice(0, 24);
}

const comunas = parseComunas(coverage.text);

function clp(n: number) {
    try {
        return new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);
    } catch {
        return '$' + String(n);
    }
}

type SliderEffect = 'fade' | 'slide';
type SliderSettings = { effect: SliderEffect; intervalMs: number; transitionMs: number };
type Slide = {
    title: string;
    subtitle: string;
    image?: string;
    imageAlt?: string;
    primaryCta?: { label: string; href: string };
    secondaryCta?: { label: string; href: string };
    align?: 'left' | 'center' | 'right';
    overlay?: string;
    textColor?: string;
};
type SliderData = { settings: SliderSettings; slides: Slide[] };

function asString(v: unknown, d = '') {
    return typeof v === 'string' ? v : d;
}
function asNumber(v: unknown, d: number) {
    const n = typeof v === 'number' ? v : Number(v);
    return Number.isFinite(n) ? n : d;
}
function clamp(n: number, min: number, max: number) {
    return Math.max(min, Math.min(max, n));
}
function normalizeSlider(raw: any): SliderData {
    const effect = asString(raw?.settings?.effect, 'fade');
    const safeEffect: SliderEffect = effect === 'slide' ? 'slide' : 'fade';
    const intervalMs = clamp(asNumber(raw?.settings?.intervalMs, 6000), 2000, 20000);
    const transitionMs = clamp(asNumber(raw?.settings?.transitionMs, 600), 150, intervalMs - 50);

    const slidesRaw = Array.isArray(raw?.slides) ? raw.slides : [];
    const slides: Slide[] = slidesRaw
        .filter((s: any) => s && typeof s === 'object')
        .slice(0, 10)
        .map((s: any) => ({
            title: asString(s.title, ''),
            subtitle: asString(s.subtitle, ''),
            image: asString(s.image, ''),
            imageAlt: asString(s.imageAlt, ''),
            primaryCta: { label: asString(s?.primaryCta?.label, ''), href: asString(s?.primaryCta?.href, '') },
            secondaryCta: { label: asString(s?.secondaryCta?.label, ''), href: asString(s?.secondaryCta?.href, '') },
            align: s.align === 'center' || s.align === 'right' ? s.align : 'left',
            overlay: asString(s.overlay, ''),
            textColor: asString(s.textColor, ''),
        }))
        .filter((s: Slide) => s.title || s.subtitle || s.image);

    if (slides.length) return { settings: { effect: safeEffect, intervalMs, transitionMs }, slides };

    return {
        settings: { effect: 'fade', intervalMs: 6000, transitionMs: 600 },
        slides: [
            {
                title: hero.title,
                subtitle: hero.subtitle,
                primaryCta: hero.ctaPrimary,
                secondaryCta: hero.ctaSecondary,
                align: 'left'
            }
        ]
    };
}

const slider = normalizeSlider(sliderRaw);
const heroMedia = slider.slides.find((s) => !!s.image) || null;
const heroImage = heroMedia?.image || '';

function safeCssUrl(u: string) {
    return (u || '').replace(/["'\\\n\r]/g, '');
}
const heroImageCss = safeCssUrl(heroImage);
const heroSlidesCss = slider.slides
    .filter((s: Slide) => !!s.image)
    .slice(0, 6)
    .map((s: Slide) => safeCssUrl(s.image || ''))
    .filter(Boolean);
const canUseSlider = sliderEnabled && heroSlidesCss.length > 1;
const slideCount = heroSlidesCss.length || 1;
const totalMs = Math.max(4000, slider.settings.intervalMs) * slideCount;

const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';
const ldJson = {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Construcciones Salas',
    url: siteUrl || undefined,
    image: heroImage || undefined,
    telephone: contact.phone || undefined,
    email: contact.email || undefined,
    areaServed: comunas.length ? comunas : ['Santiago'],
};
---

<head>
    {heroImage && <link rel="preload" as="image" href={heroImage} media="(min-width: 601px)" />}
    {canUseSlider && heroSlidesCss.slice(1, 2).map((u) => (
        <link rel="preload" as="image" href={u} media="(min-width: 601px)" />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(ldJson)}></script>
</head>

<header class="site-header">
    <div class="container header-inner">
        <a class="brand" href="#">
            <span class="brand-mark" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                    <rect x="1" y="1" width="26" height="26" rx="6" fill="currentColor"/>
                    <path d="M8 18h12v2H8v-2zm2-8h8v2h-8v-2zm1 4h6v2h-6v-2z" fill="#1F1F1F"/>
                </svg>
            </span>
            <span class="brand-text">Construcciones Salas</span>
        </a>
        <nav class="header-actions">
            <a class="btn btn-outline" href="/blog">Blog</a>
            <button
                class="btn btn-primary card-button"
                type="button"
                data-service-title="Presupuesto"
                data-service-excerpt="Cuéntanos qué necesitas y te enviamos un presupuesto."
                data-price-base="0"
                data-price-unit="visita"
                data-price-min="0"
                data-price-note="El precio final depende del trabajo y materiales."
            >
                Solicitar presupuesto
            </button>
        </nav>
    </div>
</header>

<section class={`hero ${canUseSlider ? 'hero-with-slider' : ''}`} style={heroImageCss ? `--hero-bg:url("${heroImageCss}")` : undefined}>
    {canUseSlider && (
        <div class="hero-slider-bg" style={`--hero-total-ms:${totalMs}ms;--hero-step-ms:${Math.max(4000, slider.settings.intervalMs)}ms;`} aria-hidden="true">
            {heroSlidesCss.map((u, i) => (
                <span class="hero-slide-bg" style={`--hero-i:${i};--hero-slide-bg:url("${u}")`}></span>
            ))}
        </div>
    )}
    <div class="container hero-inner">
        <div class="hero-card">
            <h1>{hero.title}</h1>
            <p>{hero.subtitle}</p>
            <div class="hero-actions">
                <a class="btn btn-primary" href="#servicios">Cotizar ahora</a>
                <a class="btn btn-outline-light" href={whatsappHref}>WhatsApp</a>
                <a class="btn btn-outline-light" href={contact.phone ? `tel:${contact.phone}` : '#'}>Llamar</a>
            </div>
            <p class="hero-trust">Más de 30 años de experiencia · Electricidad y certificación de planos eléctricos</p>
        </div>
    </div>
    <div class="hero-bg"></div>
</section>

<section class="services" id="servicios">
    <div class="container">
        <div class="section-head">
            <h2>Servicios</h2>
            <p>Selecciona un servicio y completa el presupuesto en 30 segundos.</p>
        </div>
        <div class="service-list">
            {services.map((s: any) => (
                <button
                    class="service-item card-button"
                    type="button"
                    data-service-title={s.title}
                    data-service-excerpt={s.excerpt}
                    data-price-base={s?.price?.base ?? 0}
                    data-price-unit={s?.price?.unit ?? 'servicio'}
                    data-price-min={s?.price?.min ?? 0}
                    data-price-note={s?.price?.note ?? ''}
                >
                    <div class="service-icon" aria-hidden="true">
                        {s.icon === 'bolt' && (
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                                <path d="M13 2L3 14h7l-1 8 12-12h-8l1-8z" fill="currentColor"/>
                            </svg>
                        )}
                        {s.icon === 'pipe' && (
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                                <path d="M6 4h12v4h-2v12H8V8H6V4z" stroke="currentColor" stroke-width="2" fill="none"/>
                                <circle cx="12" cy="16" r="2" fill="currentColor"/>
                            </svg>
                        )}
                        {s.icon === 'paint' && (
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                                <path d="M4 6h8l2 3h6v3h-8l-2-3H4V6z" stroke="currentColor" stroke-width="2" fill="none"/>
                                <rect x="4" y="14" width="16" height="4" rx="2" fill="currentColor"/>
                            </svg>
                        )}
                        {s.icon === 'home' && (
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                                <path d="M3 11l9-8 9 8v9a2 2 0 0 1-2 2h-4v-6H9v6H5a2 2 0 0 1-2-2v-9z" stroke="currentColor" stroke-width="2" fill="none"/>
                            </svg>
                        )}
                        {!['bolt','pipe','paint','home'].includes(s.icon) && (
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                                <path d="M13 2L3 14h7l-1 8 12-12h-8l1-8z" fill="currentColor"/>
                            </svg>
                        )}
                    </div>
                    <div class="service-main">
                        <h3>{s.title}</h3>
                        <p>{s.excerpt}</p>
                        <div class="service-meta">
                            {(() => {
                                const b = Number(s?.price?.base ?? 0);
                                const m = Number(s?.price?.min ?? 0);
                                const u = String(s?.price?.unit ?? 'servicio');
                                const p = Math.max(b, m);
                                if (p > 0) return <span class="service-price">{clp(p)} / {u}</span>;
                                return <span class="service-price service-price-muted">Precio a convenir</span>;
                            })()}
                        </div>
                    </div>
                    <div class="service-cta" aria-hidden="true">Cotizar</div>
                </button>
            ))}
        </div>
        <div class="section-cta">
            <button
                class="btn btn-primary card-button"
                type="button"
                data-service-title="Presupuesto"
                data-service-excerpt="Cuéntanos qué necesitas y te enviamos un presupuesto."
                data-price-base="0"
                data-price-unit="visita"
                data-price-min="0"
                data-price-note="El precio final depende del trabajo y materiales."
            >
                {hero.ctaPrimary?.label || 'Solicitar presupuesto'}
            </button>
        </div>
    </div>
</section>

<dialog class="cs-budget" id="cs-budget" aria-labelledby="cs-budget-title" data-wa={waDigits} data-email={contact.email || ''}>
    <form class="cs-budget-inner" id="cs-budget-form">
        <header class="cs-budget-head">
            <div>
                <h2 id="cs-budget-title">Solicitud de presupuesto</h2>
                <p class="cs-budget-sub" id="cs-budget-sub">Completa tus datos y envía por WhatsApp o correo.</p>
            </div>
            <button class="cs-budget-close" type="button" id="cs-budget-close" aria-label="Cerrar">×</button>
        </header>

        <div class="cs-budget-grid">
            <div class="cs-budget-field">
                <label for="cs-budget-service">Servicio</label>
                <input id="cs-budget-service" name="service" type="text" readonly />
            </div>
            <div class="cs-budget-field">
                <label for="cs-budget-desc">Descripción</label>
                <textarea id="cs-budget-desc" name="desc" rows="3" readonly></textarea>
            </div>

            <div class="cs-budget-field">
                <label for="cs-budget-name">Nombre</label>
                <input id="cs-budget-name" name="name" type="text" autocomplete="name" required />
            </div>
            <div class="cs-budget-field">
                <label for="cs-budget-phone">Teléfono</label>
                <input id="cs-budget-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" />
            </div>
            <div class="cs-budget-field">
                <label for="cs-budget-email">Correo</label>
                <input id="cs-budget-email" name="email" type="email" autocomplete="email" />
            </div>
            <div class="cs-budget-field">
                <label for="cs-budget-comuna">Comuna</label>
                <input id="cs-budget-comuna" name="comuna" type="text" autocomplete="address-level2" />
            </div>

            <div class="cs-budget-field cs-budget-span">
                <label for="cs-budget-details">Detalles del trabajo</label>
                <textarea id="cs-budget-details" name="details" rows="4" placeholder="Ej: revisar tablero, cambiar enchufe, reparar gotera, instalar foco…" required></textarea>
            </div>
        </div>

        <footer class="cs-budget-actions">
            <button class="btn btn-outline" type="button" id="cs-budget-copy">Copiar texto</button>
            <a class="btn btn-outline" id="cs-budget-email-btn" href="#" rel="noopener">Enviar por correo</a>
            <a class="btn btn-primary" id="cs-budget-wa-btn" href="#" rel="noopener" target="_blank">Enviar por WhatsApp</a>
        </footer>
    </form>
</dialog>

<script is:inline>
    (function () {
        const dlg = document.getElementById('cs-budget');
        const form = document.getElementById('cs-budget-form');
        const closeBtn = document.getElementById('cs-budget-close');
        if (!dlg || !(form instanceof HTMLFormElement) || !(closeBtn instanceof HTMLButtonElement)) return;

        const serviceEl = document.getElementById('cs-budget-service');
        const descEl = document.getElementById('cs-budget-desc');
        const nameEl = document.getElementById('cs-budget-name');
        const phoneEl = document.getElementById('cs-budget-phone');
        const emailEl = document.getElementById('cs-budget-email');
        const comunaEl = document.getElementById('cs-budget-comuna');
        const detailsEl = document.getElementById('cs-budget-details');
        const waBtn = document.getElementById('cs-budget-wa-btn');
        const mailBtn = document.getElementById('cs-budget-email-btn');
        const copyBtn = document.getElementById('cs-budget-copy');

        if (
            !(serviceEl instanceof HTMLInputElement) ||
            !(descEl instanceof HTMLTextAreaElement) ||
            !(nameEl instanceof HTMLInputElement) ||
            !(phoneEl instanceof HTMLInputElement) ||
            !(emailEl instanceof HTMLInputElement) ||
            !(comunaEl instanceof HTMLInputElement) ||
            !(detailsEl instanceof HTMLTextAreaElement) ||
            !(waBtn instanceof HTMLAnchorElement) ||
            !(mailBtn instanceof HTMLAnchorElement) ||
            !(copyBtn instanceof HTMLButtonElement)
        ) return;

        const digits = (v) => String(v || '').replace(/[^\d]/g, '');
        const waDigits = digits(dlg.getAttribute('data-wa') || '');
        const defaultEmail = String(dlg.getAttribute('data-email') || '');

        let note = '';
        let lastFocus = null;
        let open = false;

        const openModal = () => {
            open = true;
            document.documentElement.classList.add('cs-modal-open');
            if (typeof (dlg).showModal === 'function') {
                (dlg).showModal();
            } else {
                dlg.setAttribute('open', '');
                dlg.style.display = 'block';
            }
        };
        const closeModal = () => {
            open = false;
            document.documentElement.classList.remove('cs-modal-open');
            if (typeof (dlg).close === 'function') {
                (dlg).close();
            } else {
                dlg.removeAttribute('open');
                dlg.style.display = 'none';
            }
        };

        const ensureContactValidity = () => {
            const hasPhone = digits(phoneEl.value).length >= 8;
            const hasEmail = (emailEl.value || '').trim().length > 3;
            const ok = hasPhone || hasEmail;
            const msg = ok ? '' : 'Ingresa teléfono o correo.';
            phoneEl.setCustomValidity(msg);
            emailEl.setCustomValidity(msg);
            return ok;
        };

        const buildText = () => {
            const lines = [];
            lines.push('Solicitud de presupuesto');
            lines.push('');
            lines.push('Servicio: ' + (serviceEl.value || ''));
            if (descEl.value) lines.push('Descripción: ' + descEl.value);
            if (note) lines.push('Nota: ' + note);
            lines.push('');
            lines.push('Cliente: ' + (nameEl.value || ''));
            if (comunaEl.value) lines.push('Comuna: ' + comunaEl.value);
            if (phoneEl.value) lines.push('Teléfono: ' + phoneEl.value);
            if (emailEl.value) lines.push('Correo: ' + emailEl.value);
            lines.push('');
            lines.push('Detalles:');
            lines.push(detailsEl.value || '');
            return lines.join('\n');
        };

        const update = () => {
            const text = buildText();
            const subject = 'Presupuesto - ' + (serviceEl.value || 'Servicio');

            if (waDigits) {
                waBtn.href = 'https://wa.me/' + waDigits + '?text=' + encodeURIComponent(text);
                waBtn.setAttribute('aria-disabled', 'false');
                waBtn.style.pointerEvents = '';
                waBtn.style.opacity = '';
            } else {
                waBtn.href = '#';
                waBtn.setAttribute('aria-disabled', 'true');
                waBtn.style.pointerEvents = 'none';
                waBtn.style.opacity = '0.5';
            }

            const mailTo = defaultEmail ? ('mailto:' + encodeURIComponent(defaultEmail)) : 'mailto:';
            mailBtn.href = mailTo + '?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(text);
        };

        const validateAndUpdate = () => {
            ensureContactValidity();
            update();
        };

        document.querySelectorAll('.card-button').forEach((btn) => {
            btn.addEventListener('click', () => {
                lastFocus = btn;
                serviceEl.value = btn.getAttribute('data-service-title') || '';
                descEl.value = btn.getAttribute('data-service-excerpt') || '';
                note = btn.getAttribute('data-price-note') || '';
                validateAndUpdate();
                openModal();
                setTimeout(() => nameEl.focus(), 0);
            });
        });

        [nameEl, phoneEl, emailEl, comunaEl, detailsEl].forEach((el) => {
            el.addEventListener('input', validateAndUpdate);
        });

        copyBtn.addEventListener('click', async () => {
            ensureContactValidity();
            const text = buildText();
            try {
                await navigator.clipboard.writeText(text);
                copyBtn.textContent = 'Copiado';
                setTimeout(() => (copyBtn.textContent = 'Copiar texto'), 1200);
            } catch {}
        });

        waBtn.addEventListener('click', (e) => {
            if (!ensureContactValidity() || !form.reportValidity()) {
                e.preventDefault();
                return;
            }
            update();
        });
        mailBtn.addEventListener('click', (e) => {
            if (!ensureContactValidity() || !form.reportValidity()) {
                e.preventDefault();
                return;
            }
            update();
        });

        closeBtn.addEventListener('click', () => closeModal());
        dlg.addEventListener('cancel', (e) => {
            e.preventDefault();
            closeModal();
        });
        document.addEventListener('keydown', (e) => {
            if (!open) return;
            if (e.key === 'Escape') {
                e.preventDefault();
                closeModal();
            }
        });

        dlg.addEventListener('close', () => {
            if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
        });
    })();
</script>

<section class="about" id="sobre">
    <div class="container">
        <div class="section-head">
            <h2>{about.title}</h2>
            <p>{about.text}</p>
        </div>
    </div>
</section>

<section class="coverage" id="cobertura">
    <div class="container">
        <div class="section-head">
            <h2>{coverage.title}</h2>
            <p>{coverage.text}</p>
        </div>
        {comunas.length > 0 && (
            <ul class="comunas-grid" aria-label="Comunas de cobertura">
                {comunas.map((c) => (
                    <li class="comuna">{c}</li>
                ))}
            </ul>
        )}
    </div>
</section>

{projects.length > 0 && (
    <section class="projects" id="proyectos">
        <div class="container">
            <div class="section-head">
                <h2>Proyectos</h2>
                <p>Algunos trabajos realizados.</p>
            </div>
            <div class="grid">
                {projects.slice(0, 8).map((p: any) => (
                    <a class="tile tile-link" href={p.slug ? `/proyectos/${p.slug}` : '/proyectos'}>
                        {p.image && <img src={p.image} alt={p.title || 'Proyecto'} loading="lazy" />}
                        <h3>{p.title}</h3>
                        {p.excerpt && <p>{p.excerpt}</p>}
                    </a>
                ))}
            </div>
            <div class="section-cta">
                <a class="btn btn-outline" href="/proyectos">Ver todos los proyectos</a>
            </div>
        </div>
    </section>
)}

{testimonials.length > 0 && (
    <section class="testimonials" id="opiniones">
        <div class="container">
            <div class="section-head">
                <h2>Opiniones</h2>
