---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.PUBLIC_WP_BASE_URL;
let posts: any[] = [];

function stripHtml(v: unknown) {
    const s = typeof v === 'string' ? v : '';
    return s.replace(/<[^>]*>/g, '').trim();
}

if (base) {
    try {
        const res = await fetch(`${base}/wp-json/wp/v2/posts?per_page=12&_embed=1&orderby=date&order=desc`);
        if (res.ok) posts = await res.json();
    } catch {}
}

const items = posts.map((p) => {
    const title = stripHtml(p?.title?.rendered);
    const excerpt = stripHtml(p?.excerpt?.rendered);
    const date = typeof p?.date === 'string' ? p.date : '';
    const img = p?._embedded?.['wp:featuredmedia']?.[0]?.source_url || '';
    return { slug: p?.slug || '', title, excerpt, date, img };
});
---

<Layout
    title="Blog | Construcciones Salas"
    description="Consejos y guías de electricidad, reparaciones y mejoras para el hogar en comunas de Santiago."
>
    <main class="page">
        <header class="site-header">
            <div class="container header-inner">
                <a class="brand" href="/">
                    <span class="brand-text">Construcciones Salas</span>
                </a>
                <nav class="header-actions">
                    <a class="btn btn-outline" href="/#contacto">Pedir presupuesto</a>
                </nav>
            </div>
        </header>

        <section class="hero">
            <div class="container">
                <h1>Blog</h1>
                <p>Consejos prácticos y guías para tomar mejores decisiones antes de contratar un trabajo.</p>
            </div>
        </section>

        <section class="list">
            <div class="container">
                {items.length === 0 ? (
                    <p class="muted">Aún no hay artículos publicados.</p>
                ) : (
                    <div class="grid">
                        {items.map((p) => (
                            <article class="card">
                                {p.img && <img src={p.img} alt={p.title || 'Artículo'} loading="lazy" decoding="async" />}
                                <div class="body">
                                    {p.date && <time datetime={p.date}>{new Date(p.date).toLocaleDateString('es-CL')}</time>}
                                    <h2><a href={`/blog/${p.slug}`}>{p.title}</a></h2>
                                    {p.excerpt && <p>{p.excerpt}</p>}
                                </div>
                            </article>
                        ))}
                    </div>
                )}
            </div>
        </section>
    </main>
</Layout>

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: var(--bg);
        border-bottom: 1px solid #eaeaea;
    }
    .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
    }
    .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-weight: 700;
        letter-spacing: 0.2px;
    }
    .brand-text {
        color: var(--dark);
        font-size: 18px;
    }
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 600;
        transition: transform .08s ease, box-shadow .2s ease, background .2s ease, color .2s ease, border-color .2s ease;
    }
    .btn-outline {
        border: 2px solid var(--dark);
        color: var(--dark);
        background: transparent;
    }
    .btn-outline:hover {
        border-color: var(--accent);
        color: var(--accent);
    }
    .hero {
        padding: 36px 0;
        background: var(--bg-muted);
    }
    .hero h1 {
        font-size: 34px;
        line-height: 1.15;
        margin: 0 0 10px;
    }
    .hero p {
        margin: 0;
        color: #5a5a5a;
        max-width: 70ch;
        line-height: 1.6;
    }
    .list {
        padding: 44px 0 64px;
    }
    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }
    .card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 1px 0 rgba(0,0,0,.04), 0 8px 18px rgba(0,0,0,.04);
        display: grid;
    }
    .card img {
        width: 100%;
        aspect-ratio: 16/10;
        object-fit: cover;
        border-bottom: 1px solid #f0f0f0;
    }
    .body {
        padding: 14px 16px 16px;
        display: grid;
        gap: 8px;
    }
    time {
        font-size: 12px;
        color: #7a7a7a;
    }
    h2 {
        font-size: 18px;
        line-height: 1.25;
        margin: 0;
    }
    h2 a:hover {
        color: var(--accent);
    }
    .body p {
        margin: 0;
        color: #5a5a5a;
        line-height: 1.6;
    }
    .muted {
        color: #5a5a5a;
    }
    @media (max-width: 900px) {
        .grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 600px) {
        .grid { grid-template-columns: 1fr; }
    }
</style>
